        },
        "measured": {
          "width": 150,
          "height": 136
        },
        "nodeType": "default",
        "formDataValid": true
      }
    },
    {
      "id": "prompt_1",
      "provider": "prompt",
      "config": {
        "instructions": [
          "You are a grounded research ideation assistant. Your job is to propose plausible future research directions using only the supplied professor and paper evidence. Rules: - Use only the supplied prompt. - Do not invent unsupported trends or claims. - Keep ideas realistic, specific, and adjacent to the evidence. - Prefer ideas that build on the professor's existing themes or meaningful nearby intersections. - Return plain text only. - When asked for multiple directions, output one direction per line."
        ],
        "parameters": {
          "google": {}
        }
      },
      "ui": {
        "position": {
          "x": 487.5,
          "y": 65
        },
        "measured": {
          "width": 150,
          "height": 119
        },
        "nodeType": "default",
        "formDataValid": true
      },
      "input": [
        {
          "lane": "text",
          "from": "webhook_1"
        }
      ]
    },
    {
      "id": "llm_openai_1",
      "provider": "llm_openai",
      "config": {
        "profile": "openai-5-mini",
        "openai-5-2": {},
        "parameters": {
          "google": {}
        },
        "openai-5-mini": {
